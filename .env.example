# === Локальный запуск БЕЗ Docker (Windows) ===
# 1) Установите PostgreSQL, создайте БД и пользователя (см. docs/SETUP-WINDOWS-NO-DOCKER.md)
# 2) Скопируйте этот файл в .env:  Copy-Item .env.example .env

# Database (PostgreSQL на localhost)
# Пример после CREATE USER moscasting / CREATE DATABASE moscasting:
DATABASE_URL="postgresql://moscasting:moscasting@localhost:5432/moscasting?schema=public"

# Если ходите под суперпользователем postgres (только для локалки):
# DATABASE_URL="postgresql://postgres:ВАШ_ПАРОЛЬ@localhost:5432/moscasting?schema=public"

# Auth.js — в production используйте случайную строку ≥ 32 символов
AUTH_SECRET="change-me-in-production-use-long-random-string"
AUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_NAME="МОСКАСТИНГ"
NEXT_PUBLIC_DEFAULT_CITY_SLUG="moscow"

# S3-compatible storage (опционально для MVP)
S3_ENDPOINT=""
S3_REGION="ru-central1"
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_PUBLIC_BASE_URL=""
